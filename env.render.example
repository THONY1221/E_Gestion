# Configuration pour Render.com avec PostgreSQL
NODE_ENV=production
PORT=10000

# Configuration base de données PostgreSQL (Render fournit DATABASE_URL automatiquement)
DATABASE_URL=postgresql://user:password@hostname:port/database_name

# Configuration JWT
JWT_SECRET=VotreSecretJWTTresLongEtComplexe123456789!
JWT_EXPIRY=1d

# Chemins uploads (Render utilise /tmp pour les fichiers temporaires)
UPLOAD_DIR=/tmp/uploads

# Configuration PDF (Puppeteer) pour Render
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage,--disable-gpu

# Configuration CORS pour votre frontend Vercel
CORS_ORIGIN=https://elsa-gestion-front-end.vercel.app

# Configuration de sécurité
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Configuration email (optionnel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASS=votre-mot-de-passe-app 