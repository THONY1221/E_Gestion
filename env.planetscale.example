# Configuration PlanetScale pour le backend
NODE_ENV=production
PORT=3000

# Base de données PlanetScale MySQL
DATABASE_URL=mysql://username:password@aws.connect.psdb.cloud/database-name?ssl={"rejectUnauthorized":true}

# OU paramètres séparés PlanetScale
PLANETSCALE_HOST=aws.connect.psdb.cloud
PLANETSCALE_PORT=3306
PLANETSCALE_USER=votre-username
PLANETSCALE_PASSWORD=votre-password
PLANETSCALE_DATABASE=votre-database-name

# JWT Secret
JWT_SECRET=votre_secret_jwt_tres_long_et_complexe_pour_production

# Upload paths
UPLOAD_DIR=./uploads
TEMP_IMPORT_DIR=./uploads/temp_imports

# CORS
ALLOWED_ORIGINS=https://elsa-gestion-front-end.vercel.app,http://localhost:3000 