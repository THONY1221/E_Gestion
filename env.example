# Configuration serveur
NODE_ENV=production
PORT=3000

# Configuration base de données Supabase/PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/database
# OU utiliser les paramètres séparés :
DB_HOST=db.oalzqdjcxgeigggkgfszv.supabase.co
DB_USER=postgres
DB_PASSWORD=VotreMotDePasseSupabase
DB_NAME=postgres
DB_PORT=5432

# Configuration JWT
JWT_SECRET=VotreSecretJWTTresLongEtComplexe123456789!
JWT_EXPIRY=1d

# Chemins uploads (pour le déploiement local)
UPLOAD_DIR=./uploads

# Configuration PDF (Puppeteer) - Render.com
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# Configuration email (optionnel)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=votre-email@gmail.com
# SMTP_PASS=votre-mot-de-passe-app

